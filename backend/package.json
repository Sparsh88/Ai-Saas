{
  "name": "skillforge-ai-backend",
  "version": "1.0.0",
  "description": "Backend API server for SkillForge AI SaaS platform",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
