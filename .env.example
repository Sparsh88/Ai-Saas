# Server Configuration
PORT=5000

# PostgreSQL Database Connection (Replace with your own database URL)
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_HOST:5432/YOUR_DB_NAME?sslmode=require"

# JWT Secrets (Generate secure random strings for production)
JWT_ACCESS_SECRET="your_jwt_access_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Google Gemini API Key (Optional)
GEMINI_API_KEY=""

# Cloudinary Storage Configuration (Optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Razorpay Payment Gateway (Optional)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
